# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://www.yourdomain.com
NEXT_PUBLIC_APP_NAME=STUDY'S

# Storage
NEXT_PUBLIC_STORAGE_BUCKET=studys-uploads

# Push notifications (Web Push / VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Sécurité interne
INTERNAL_API_KEY=your-random-secret-string

# Postmark (emails transactionnels — configuré dans Supabase SMTP, pas utilisé directement)
# Host: smtp.postmarkapp.com | Port: 587 | User+Password: Server API Token
# POSTMARK_API_TOKEN=your-postmark-server-api-token
